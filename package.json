{
  "name": "productivedude",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node inline-assets.js",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "vite & sleep 2 && NODE_ENV=development electron .",
    "electron:run": "NODE_ENV=production electron .",
    "electron:build": "npm run build && electron-builder",
    "mobile:init": "npx cap init PRODUCTIVEDUDE com.productivedude.lifeos dist && npx cap add android",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@tailwindcss/vite": "^4.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^1.22.0",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.1",
    "vite": "^8.1.0"
  },
  "build": {
    "appId": "com.productivedude.lifeos",
    "productName": "PRODUCTIVEDUDE",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
